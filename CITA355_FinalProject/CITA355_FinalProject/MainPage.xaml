<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CITA355_FinalProject.MainPage">
    <ScrollView>
        <VerticalStackLayout>
            <HorizontalStackLayout 
                HorizontalOptions = "Center"
                Spacing="10">

                <Button x:Name ="buttonHome" Text="Home" Clicked="OnHomeClicked" MinimumWidthRequest="100"/>
                <Button x:Name ="buttonLogin" Text="Login" Clicked="OnLoginClicked" MinimumWidthRequest="100"/>
                <Button x:Name ="buttonCreateAccount" Text="Create Account" Clicked="OnCreateAccountClicked" MinimumWidthRequest="100"/>
                <Button x:Name ="buttonSearchDatabase" Text="Search Database" Clicked="OnSearchDatabaseClicked" MinimumWidthRequest="100"/>
            </HorizontalStackLayout>

            <Label x:Name="labelGreetUser" IsVisible="False"/>
            <Button x:Name="buttonTakeQuiz" Text="Take Quiz" Clicked="OnButtonTakeQuizClicked" IsVisible="False"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
