<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CITA355_FinalProject.LoginPage">

    <ScrollView>
        <VerticalStackLayout Spacing="25" Padding="25">
            <HorizontalStackLayout 
                HorizontalOptions = "Center"
                Spacing="10">

                <Button x:Name ="buttonHome" Text="Home" Clicked="OnHomeClicked" MinimumWidthRequest="100"/>
                <Button x:Name ="buttonLogin" Text="Login" Clicked="OnLoginClicked" MinimumWidthRequest="100"/>
                <Button x:Name ="buttonCreateAccount" Text="Create Account" Clicked="OnCreateAccountClicked" MinimumWidthRequest="100"/>
                <Button x:Name ="buttonSearchDatabase" Text="Search Database" Clicked="OnSearchDatabaseClicked" MinimumWidthRequest="100"/>
            </HorizontalStackLayout>

            <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto, Auto, Auto, Auto" RowSpacing="10" ColumnSpacing="20">
                <Label x:Name="labelEmail" Text="Email: " Grid.Row ="0" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="End"/>
                <Entry x:Name ="entryEmailOrID" Grid.Row="0" Grid.Column="1" VerticalOptions="Center"/>

                <Label x:Name="labelPassword" Text="Password: " Grid.Row ="1" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="End"/>
                <Entry x:Name ="entryPassword" Grid.Row="1" Grid.Column="1" VerticalOptions="Center"/>

                <Button Text="Login" Clicked="OnSubmitLogin" Grid.Row="2" Grid.Column="0"/>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
