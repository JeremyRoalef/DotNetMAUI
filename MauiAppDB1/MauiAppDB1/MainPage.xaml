<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppDB1.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Button Text="Load Students" Clicked="LoadStudents"/>
            <Button Text="Add Student" Clicked="AddStudent"/>
            <CollectionView x:Name="studentList">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout>
                            <Label Text="{Binding name}" FontSize="20"/>
                            <Label Text="{Binding dept_name}" FontSize="18"/>
                            <Label Text="{Binding gpa}"/>
                            <Label Text="{Binding email}"/>
                            <Button Text="Update Info" Clicked="OnUpdateStudent" CommandParameter="{Binding .}"/>
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
