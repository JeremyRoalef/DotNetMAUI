<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppDB1.AddStudent">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">

            <Entry Placeholder="ID" x:Name="entryID"/>
            <Entry Placeholder="Name" x:Name="entryName"/>
            <Entry Placeholder="Department Name" x:Name="entryDeptName"/>
            <Entry Placeholder="GPA" x:Name="entryGPA"/>
            <Entry Placeholder="Email" x:Name="entryEmail"/>
            <Button Text="Submit" Clicked="OnSubmitClicked"/>

            <Label x:Name="labelResponse"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
