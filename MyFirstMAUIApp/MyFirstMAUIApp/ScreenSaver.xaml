    <Grid x:Name="screenSaverArea">
        <!---Create the Screen Saver sprite-->
        <Image x:Name="imgScreenSaver"
           Source="spr_screen_saver.png"
           WidthRequest="200"
           HeightRequest="100">
        </Image>
    </Grid>
</ContentPage>
