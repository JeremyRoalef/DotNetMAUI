<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MyFirstMAUIApp.MainPage">
    <VerticalStackLayout Padding='30'>
        <Label Text="Welcome to My First App" FontSize="24" HorizontalOptions="Center" />
        <Entry x:Name="nameEntry" Placeholder="Enter your name"/>
        <Button Text="Greet Me" Clicked="OnButtonClicked"/>
        <Button Text="Clear" Clicked="OnButtonClearClicked"/>
        <Label x:Name="resultLabel" FontSize="18"/>
    </VerticalStackLayout>

</ContentPage>
