<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="EventPlanner.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:EventPlanner"
    Title="EventPlanner">

    <ShellContent
        ContentTemplate="{DataTemplate local:EventSelection}"
        Route="EventSelection" />
    
    <!--Flyout Menu-->
    <MenuItem Text="Home" Clicked="OnHomeClicked">

    </MenuItem>
    <MenuItem Text="Earth Day" Clicked="OnEarthDayClicked">

    </MenuItem>
    <MenuItem Text="Book Club" Clicked="OnBookClubClicked">

    </MenuItem>
    <MenuItem Text="Applied Student Learning Showcase" Clicked="OnAppliedStudentLearningClicked">

    </MenuItem>
</Shell>
